<script>
const ss=document.querySelectorAll('.slide');
let c=0;
function go(n){
  ss[c].classList.remove('on');
  c=Math.max(0,Math.min(n,ss.length-1));
  ss[c].classList.add('on');
  ss[c].scrollTop=0;
  document.getElementById('ctr').textContent=(c+1)+' / '+ss.length+'  ·  '+ss[c].dataset.t;
  document.getElementById('pf').style.width=(c/(ss.length-1)*100)+'%';
  document.getElementById('bp').disabled=c===0;
  document.getElementById('bn').disabled=c===ss.length-1;
}
function mv(d){go(c+d);}
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown')mv(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')mv(-1);
});
go(0);
</script>
